# Supabase (Project Settings → API)
VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# --- Phase 2 (LiveKit), added next ---
# LIVEKIT_URL=wss://YOUR-livekit-host
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# SUPABASE_SERVICE_ROLE_KEY=   # server-only, used by the token function to read participants

# --- Phase 2: LiveKit (now active) ---
LIVEKIT_URL=wss://YOUR-project.livekit.cloud
LIVEKIT_API_KEY=APIxxxxxxxx
LIVEKIT_API_SECRET=xxxxxxxxxxxxxxxx

# Server-side Supabase (Netlify functions) — non-VITE
SUPABASE_URL=https://YOUR-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Recording storage (skip if using LiveKit Cloud built-in egress storage)
S3_ACCESS_KEY=
S3_SECRET=
S3_BUCKET=rostrum-recordings
S3_REGION=us-east-1
